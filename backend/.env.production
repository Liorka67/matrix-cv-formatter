# ──────────────────────────────────────────────────────────────
# PRODUCTION env template — set these in Render dashboard, NOT here
# ──────────────────────────────────────────────────────────────
NODE_ENV=production

# Your Anthropic API key (set as a secret in Render dashboard)
ANTHROPIC_API_KEY=

# ⚠️  app.ts currently validates OPENAI_API_KEY (leftover from migration).
#     Until that line is fixed, also set this in Render dashboard:
OPENAI_API_KEY=placeholder

# Render sets PORT automatically — do not override
# PORT is handled by Render
